// Prisma schema for AI Engineer Portfolio

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model ContactMessage {
  id        String   @id @default(auto()) @map("_id")
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}
